user = "{{ user }}"
serverAddr = "{{ server_addr }}"
serverPort = {{ server_port }}
loginFailExit = {{ "true" if login_fail_exit else "false" }}
{% if includes_enabled %}
includes = ["{{ includes_glob }}"]
{% endif %}

[transport]
protocol = "{{ transport_protocol }}"

{% if web_server.addr and web_server.port %}
[webServer]
addr = "{{ web_server.addr }}"
port = {{ web_server.port }}
{% endif %}

[log]
{% if log.to %}to = "{{ log.to }}"
{% endif %}level = "{{ log.level }}"
maxDays = {{ log.max_days }}
disablePrintColor = {{ "true" if log.disable_print_color else "false" }}

[auth]
method = "{{ auth.method }}"
{% if auth.token %}token = "{{ auth.token }}"
{% endif %}

{% if auth.token_file %}
[auth.tokenSource]
type = "file"

[auth.tokenSource.file]
path = "{{ auth.token_file }}"
{% endif %}
